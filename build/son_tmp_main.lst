.................... uint16_t read_adc_internal(void);
.................... 
.................... // жЄ©еЇ¶и®ИжЄђгВЈгГЉгВ±гГ≥гВєгБЃеЃЯи°МгБ®FlashгБЄгБЃдњЭе≠Ш
.................... // startPacketNum: йЦЛеІЛгГСгВ±гГГгГИзХ™еПЈ (19)
.................... // packetCount: еЃЯи°МгБЩгВЛгГСгВ±гГГгГИжХ∞ (14)
.................... void execute_temp_measurement(uint8_t startPacketNum, uint8_t packetCount);

.................... 
....................     // ------------------------------------------
....................     // SPI йҖҡдҝЎиЁӯе®ҡ
....................     // ------------------------------------------
....................     #pin_select SDI2=PIN_B5     // MISO
....................     #pin_select SDO2=PIN_B4     // MOSI
....................     #pin_select SCK2OUT=PIN_B2  // CLK
....................     #pin_select SCK2IN=PIN_B2
....................     #use spi(MASTER, SPI2, BAUD=1000000, MODE=0, BITS=8, stream=MIS_FM_STREAM)

.................... 
.................... // مƒ•مƒ©مƒƒم‚·مƒ¥م‚«م‚¦مƒ³م‚؟و§‹é€ ن½“ (11 Bytes)
.................... typedef struct
.................... {
....................     uint8_t   mission_id;

.................... // хдЦщГихЕмщЦЛщЦвцХ░уГЧуГнуГИуВ┐уВдуГЧ
.................... // ============================================================================
.................... 
.................... // уГЪуГкуГХуВзуГйуГлуБохИЭцЬЯхМЦ (уГФуГ│уБохЗ║хКЫшинхоЪуБкуБй)
.................... void io_init(void);
.................... 
.................... // уВвуГКуГнуВ░уВ╣уВдуГГуГБуБохИЗуВКцЫ┐уБИ (0уАЬ3уГБуГгуГ│уГНуГл)
.................... void switch_channel(uint8_t ch);
.................... 
.................... // LTC2452уБЛуВЙ16bitуБоADCхАдуВТшкнуБ┐хПЦуВЛ
.................... uint16_t read_adc_ltc2452(void);
.................... 
.................... // шиИц╕муВ╖уГ╝уВ▒уГ│уВ╣уБохоЯшбМуБиFlashуБ╕уБоф┐ЭхнШ (IVуГЗуГ╝уВ┐ я╝Л ц╕йх║жуГЗуГ╝уВ┐уВТщАгч╢ЪхоЯшбМ)
.................... // mode: хЛХф╜ЬуГвуГ╝уГЙ
.................... // channel: ц╕мхоЪуГБуГгуГ│уГНуГл (MAX4734EUB+ уБощБ╕цКЮ)
.................... // samplingRate: уВ╡уГ│уГЧуГкуГ│уВ░уГмуГ╝уГИшинхоЪхАд
.................... void execute_measurement(uint8_t mode, uint8_t channel, uint8_t samplingRate);
.................... 

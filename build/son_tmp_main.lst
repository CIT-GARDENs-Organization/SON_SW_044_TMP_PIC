....................         // сЃЄсЃ╝сѓ┐сЂїжђћтѕЄсѓїсѓІ№╝ѕ5msжќЊуёАжђџС┐А№╝ЅсЂЙсЂДтЁетіЏсЂДтљИсЂёСИісЂњсѓІ
....................         while(timeout_ms < 5)
....................         {
....................             if (uart_has_data()) {
....................                 if (boss_receive_buffer_size < RECEIVE_BUFFER_MAX) {
....................                     boss_receive_buffer[boss_receive_buffer_size++] = uart_getc();
....................                 } else {
....................                     uart_getc(); // Т║ђТЮ»ТЎѓсЂ»ТЇесЂдсѓІ
....................                 }
....................                 timeout_ms = 0;
....................             } else {
....................                 delay_ms(1);
....................                 timeout_ms++;
....................             }
....................         }
....................     }
.................... }

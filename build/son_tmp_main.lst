.................... 
.................... // مƒ†مƒ¼مƒ–مƒ«ن؟‌ه­کç”¨مپ®64Byteمƒ‘م‚±مƒƒمƒˆو§‹é€ ن½“
.................... typedef union
.................... {
....................     struct
....................     {
....................         union
....................         {

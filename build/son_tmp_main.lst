.................... #ifndef SON_TMP_FLASH_H
.................... #define SON_TMP_FLASH_H
.................... 
.................... #include <stdint.h>
.................... #include <string.h>
.................... #include "../../system/son_tmp_config.h"
.................... 
.................... // ============================================================================
.................... // жЦ∞гБЧгБДгГ°гГҐгГ™гГЮгГГгГЧеЃЪзЊ© (MT25QL128ABA: 16MB)
.................... // ============================================================================
.................... #define MISF_START 0x00000000
.................... #define MISF_END   0x00FFFFFF
.................... 
.................... #define SECTOR_64K_BYTE  0x10000
.................... 
.................... // ----------------------------------------------------
.................... // 1. зЃ°зРЖзФ®гГЗгГЉгВњй†ШеЯЯ (4KB гВµгГЦгВїгВѓгВњ √Ч 2)
.................... // ----------------------------------------------------
.................... #define MISF_TMP_DATA_TABLE_SIZE     64
.................... #define MISF_TMP_DATA_TABLE_START    0x00000000
.................... #define MISF_TMP_DATA_TABLE_END      0x00000FFF // 1гБ§зЫЃ (4KB)
.................... #define MISF_TMP_DATA_TABLE_BK_START 0x00001000 // 2гБ§зЫЃ (гГРгГГгВѓгВҐгГГгГЧ/йААйБњзФ®: 4KB)
.................... #define MISF_TMP_DATA_TABLE_BK_END   0x00001FFF
.................... 
.................... // ----------------------------------------------------
.................... // 2. PICLOG й†ШеЯЯ (64KB гВїгВѓгВњ √Ч 1)
.................... // вАїйА±1еЫЮгБЃйБЛзФ®гБІ1еєійЦУгБЂзіД3.3KBжґИи≤їгАВзіД19еєіеИЖдњЭе≠ШеПѓиГљгАВ
.................... // ----------------------------------------------------
.................... #define MISF_TMP_PICLOG_START        0x00010000
.................... #define MISF_TMP_PICLOG_END          0x0001FFFF
.................... 
.................... // ----------------------------------------------------
.................... // 3. STRгГЗгГЉгВњй†ШеЯЯ (жЃЛгВКгБЩгБєгБ¶: зіД15.8MB)
.................... // вАїеЇГе§ІгБ™гГ≠гГЉгВЂгГЂгГРгГГгГХгВ°гБ®гБЧгБ¶дљњзФ®гАВжЬ™йАБдњ°еИЖгВТгБУгБУгБЛгВЙCPLDгБЄйАБгВЛгАВ
.................... // ----------------------------------------------------
.................... #define MISF_TMP_STR_DATA_START      0x00020000
.................... #define MISF_TMP_STR_DATA_END        0x00FFFFFF
.................... 
.................... // ============================================================================
.................... // гГЗгГЉгВњжІЛйА†дљУеЃЪзЊ©
.................... // ============================================================================
.................... 
.................... // гГХгГ©гГГгВЈгГ•гВЂгВ¶гГ≥гВњжІЛйА†дљУ (11 Bytes)
.................... typedef struct
.................... {
....................     uint8_t   mission_id;
....................     uint32_t  used_counter;
....................     uint32_t  uncopied_counter;
....................     uint8_t   reserve_counter1;
....................     uint8_t   reserve_counter2;
.................... } Flash_t;
.................... 
.................... // гГЖгГЉгГЦгГЂдњЭе≠ШзФ®гБЃ64ByteгГСгВ±гГГгГИжІЛйА†дљУ
.................... typedef union
.................... {
....................     struct
....................     {
....................         union
....................         {
....................             struct
....................             {
....................                 Flash_t piclog;
....................                 Flash_t str_data;
....................             } logdata;
....................             uint8_t reserve[63];
....................         } payload;
....................         uint8_t crc; // 1гГРгВ§гГИгБЃCRC
....................     } packet;
....................     uint8_t bytes[64];
.................... } FlashData_t;
.................... 
.................... typedef struct
.................... {
....................     uint32_t start_address;
....................     uint32_t end_address;
.................... } MisfStatusStruct;
.................... 
.................... typedef struct
.................... {
....................     uint32_t start_address;
....................     uint32_t size;
.................... } MisfWriteStruct;
.................... 
.................... // ============================================================================
.................... // гВ∞гГ≠гГЉгГРгГЂе§ЙжХ∞ (еЃ£и®АгБЃгБњгАБеЃЯдљУгБѓ.cгГХгВ°гВ§гГЂгБЂи®Шињ∞)
.................... // ============================================================================
.................... extern Flash_t piclog_data;
.................... extern Flash_t str_data;
.................... 
.................... // ============================================================================
.................... // е§ЦйГ®еЕђйЦЛйЦҐжХ∞гГЧгГ≠гГИгВњгВ§гГЧ
.................... // ============================================================================
.................... void misf_init(void);

.................... // ============================================================================
.................... // жё©еәҰгғҮгғјгӮҝз”Ёгғ‘гӮұгғғгғҲж§ӢйҖ дҪ“ (64Byte)
.................... // ============================================================================
.................... typedef struct
.................... {
....................     uint8_t packetNum;       // гғ‘гӮұгғғгғҲз•ӘеҸ· (1 Byte)
....................     uint8_t tempData[62];    // жё©еәҰгғҮгғјгӮҝжң¬дҪ“ (62 Byte = 12bit x 41гғҮгғјгӮҝ)
....................     uint8_t crc8;            // CRC-8 (1 Byte)
.................... } TempPacket;
.................... 
.................... // гғЎгғўгғӘгғҗгғғгғ•гӮЎз”Ёе…ұз”ЁдҪ“
.................... typedef union
.................... {
....................     uint8_t raw[PACKET_SIZE];
....................     TempPacket temp;
.................... } TempPacketBuffer;
.................... 
.................... // ============================================================================
.................... // еӨ–йғЁе…¬й–Ӣй–ўж•°гғ—гғӯгғҲгӮҝгӮӨгғ—
.................... // ============================================================================
.................... 
.................... // еҶ…и”өADCгҒ®еҲқжңҹеҢ–
.................... void temp_io_init(void);
.................... 
.................... // еҶ…и”өADCгҒӢгӮүжё©еәҰгӮ»гғігӮөгғјгҒ®еҖӨгӮ’иӘӯгҒҝеҸ–гӮӢ (12bit)
.................... uint16_t read_adc_internal(void);
.................... 
.................... // жё©еәҰиЁҲжё¬гӮ·гғјгӮұгғігӮ№гҒ®е®ҹиЎҢгҒЁFlashгҒёгҒ®дҝқеӯҳ
.................... // startPacketNum: й–Ӣе§Ӣгғ‘гӮұгғғгғҲз•ӘеҸ· (19)
.................... // packetCount: е®ҹиЎҢгҒҷгӮӢгғ‘гӮұгғғгғҲж•° (14)
.................... void execute_temp_measurement(uint8_t startPacketNum, uint8_t packetCount);
.................... 
.................... #endif // son_tmp_TEMP_H

....................     {
....................         mis_write_struct.start_address = MISF_TMP_STR_DATA_START + str_data.used_counter - str_data.uncopied_counter;
....................         mis_write_struct.size = str_data.uncopied_counter;
....................     }
.................... 
....................     return mis_write_struct;
.................... }

.................... #define CMD_SMF_ERASE                0x92
.................... #define CMD_SMF_COPY_FORCE           0x93
.................... #define CMD_SMF_READ_FORCE           0x94
.................... #define CMD_SMF_ERASE_FORCE          0x95
.................... 
.................... // --- УеѕТИг (Strain) жќбжђБ ---
.................... #define CMD_STR                      0xA0
.................... #define CMD_STR_DEBUG                0xA1
.................... #define CMD_STR_PRINT                0xA2
.................... #define CMD_STR_DEBUG_SAVE           0xA3
.................... #define CMD_MISSION_ABORT            0xAF
.................... 
.................... // --- сЂЮсЂ«С╗ќ ---
.................... #define CMD_RETURN_TIME              0xB0
.................... 
.................... // РўЁС┐«ТГБ: уЅЕуљєуџёсЂФADCтЄдуљєсЂїжќЊсЂФтљѕсѓЈсЂфсЂёсЂЪсѓЂ 10ms, 50ms сЂ«УеГт«џсѓњжЎцтцќсЂЌсЂЙсЂЌсЂЪ
.................... // #define SAMP_RATE_10MS               0x01  // 0.01уДњ
.................... // #define SAMP_RATE_50MS               0x02  // 0.05уДњ
.................... #define SAMP_RATE_100MS              0x03  // 0.10уДњ
.................... #define SAMP_RATE_500MS              0x04  // 0.50уДњ
.................... #define SAMP_RATE_1000MS             0x05  // 1.00уДњ
.................... #define SAMP_RATE_5000MS             0x06  // 5.00уДњ
.................... #define SAMP_RATE_2432MS             0x07  // 2.432уДњ (0.25тЉетЏъжђБуХџУеѕТИг)
.................... #define SAMP_RATE_4865MS             0x08  // 4.865уДњ (0.5тЉетЏъжђБуХџУеѕТИг)
.................... #define SAMP_RATE_9730MS             0x09  // 9.730уДњ (1тЉетЏъжђБуХџУеѕТИг)

.................... 
.................... // ============================================================================
.................... // Тќ░сЂЌсЂёсЃАсЃбсЃфсЃъсЃЃсЃЌт«џуЙЕ (MT25QL128ABA: 16MB)
.................... // ============================================================================
.................... #define MISF_START 0x00000000
.................... #define MISF_END   0x00FFFFFF
.................... 
.................... #define SECTOR_64K_BYTE  0x10000
.................... 
.................... // ----------------------------------------------------
.................... // 1. у«АуљєућесЃЄсЃ╝сѓ┐жаўтЪЪ (4KB сѓхсЃќсѓ╗сѓ»сѓ┐ ├Ќ 2)
.................... // ----------------------------------------------------
.................... #define MISF_TMP_DATA_TABLE_SIZE     64
.................... #define MISF_TMP_DATA_TABLE_START    0x00000000
.................... #define MISF_TMP_DATA_TABLE_END      0x00000FFF // 1сЂцуЏ« (4KB)
.................... #define MISF_TMP_DATA_TABLE_BK_START 0x00001000 // 2сЂцуЏ« (сЃљсЃЃсѓ»сѓбсЃЃсЃЌ/жђђжЂ┐уће: 4KB)
.................... #define MISF_TMP_DATA_TABLE_BK_END   0x00001FFF
.................... 
.................... // ----------------------------------------------------
.................... // 2. PICLOG жаўтЪЪ (64KB сѓ╗сѓ»сѓ┐ ├Ќ 1)
.................... // Рђ╗жђ▒1тЏъсЂ«жЂІућесЂД1т╣┤жќЊсЂФу┤ё3.3KBТХѕУ▓╗сђѓу┤ё19т╣┤тѕєС┐ЮтГўтЈ»УЃйсђѓ
.................... // ----------------------------------------------------
.................... #define MISF_TMP_PICLOG_START        0x00010000
.................... #define MISF_TMP_PICLOG_END          0x0001FFFF
.................... 
.................... // ----------------------------------------------------
.................... // 3. STRсЃЄсЃ╝сѓ┐жаўтЪЪ (Т«ІсѓісЂЎсЂ╣сЂд: у┤ё15.8MB)
.................... // Рђ╗т║ЃтцДсЂфсЃГсЃ╝сѓФсЃФсЃљсЃЃсЃЋсѓАсЂесЂЌсЂдСй┐ућесђѓТюфжђЂС┐АтѕєсѓњсЂЊсЂЊсЂІсѓЅCPLDсЂИжђЂсѓІсђѓ
.................... // ----------------------------------------------------
.................... #define MISF_TMP_STR_DATA_START      0x00020000
.................... #define MISF_TMP_STR_DATA_END        0x00FFFFFF
.................... 
.................... // ============================================================================
.................... // сЃЄсЃ╝сѓ┐ТДІжђаСйЊт«џуЙЕ
.................... // ============================================================================
.................... 
.................... // сЃЋсЃЕсЃЃсѓисЃЦсѓФсѓдсЃ│сѓ┐ТДІжђаСйЊ (11 Bytes)
.................... typedef struct
.................... {
....................     uint8_t   mission_id;
....................     uint32_t  used_counter;
....................     uint32_t  uncopied_counter;
....................     uint8_t   reserve_counter1;
....................     uint8_t   reserve_counter2;
.................... } Flash_t;
.................... 
.................... // сЃєсЃ╝сЃќсЃФС┐ЮтГўућесЂ«64ByteсЃЉсѓ▒сЃЃсЃѕТДІжђаСйЊ
.................... typedef union
.................... {
....................     struct
....................     {
....................         union
....................         {
....................             struct
....................             {
....................                 Flash_t piclog;
....................                 Flash_t str_data;
....................             } logdata;
....................             uint8_t reserve[63];
....................         } payload;
....................         uint8_t crc; // 1сЃљсѓцсЃѕсЂ«CRC
....................     } packet;
....................     uint8_t bytes[64];
.................... } FlashData_t;
.................... 
.................... typedef struct
.................... {
....................     uint32_t start_address;
....................     uint32_t end_address;
.................... } MisfStatusStruct;
.................... 
.................... typedef struct
.................... {
....................     uint32_t start_address;
....................     uint32_t size;
.................... } MisfWriteStruct;
.................... 
.................... // ============================================================================
.................... // сѓ░сЃГсЃ╝сЃљсЃФтцЅТЋ░ (т«БУеђсЂ«сЂ┐сђЂт«ЪСйЊсЂ».cсЃЋсѓАсѓцсЃФсЂФУеўУ┐░)
.................... // ============================================================================
.................... extern Flash_t piclog_data;
.................... extern Flash_t str_data;
.................... 
.................... // ============================================================================
.................... // тцќжЃетЁгжќІжќбТЋ░сЃЌсЃГсЃѕсѓ┐сѓцсЃЌ

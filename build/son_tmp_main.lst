.................... void temp_io_init(void)
.................... {
....................     fprintf(PC, "Temp IO Initialize\r\n");
*
00B88:  MOVLW  52
00B8A:  MOVWF  FF6
00B8C:  MOVLW  04
00B8E:  MOVWF  FF7
00B90:  MOVLW  00
00B92:  MOVWF  FF8
00B94:  CALL   0B22
.................... 
....................     // ※ 実際のハードウェア配線に合わせて sANx (アナログピン) を調整してください
....................     // ここでは仮に AN0 (sAN0) を使用する設定としています
....................     setup_adc_ports(sAN0);
00B98:  MOVLB  E
00B9A:  CLRF   x45
00B9C:  CLRF   x46
00B9E:  MOVLW  01
00BA0:  MOVWF  x47
00BA2:  BCF    x8D.7
00BA4:  BCF    x8D.6
00BA6:  BCF    x8D.5
....................     setup_adc(ADC_CLOCK_INTERNAL);
00BA8:  MOVLW  9F
00BAA:  MOVWF  x8B
00BAC:  CLRF   x8A
00BAE:  MOVLW  70
00BB0:  MOVWF  FC0
00BB2:  MOVLW  82
00BB4:  MOVWF  FC1
....................     set_adc_channel(0);
00BB6:  CLRF   x86
.................... 
....................     fprintf(PC, "\tComplete\r\n");
00BB8:  MOVLW  68
00BBA:  MOVWF  FF6
00BBC:  MOVLW  04
00BBE:  MOVWF  FF7
00BC0:  MOVLW  00
00BC2:  MOVWF  FF8
00BC4:  MOVLB  0
00BC6:  CALL   0B22
00BCA:  RETURN 0
.................... }
.................... 
.................... uint16_t read_adc_internal(void)
.................... {
....................     // ADCのチャネル切り替え・サンプリング安定待ち
....................     delay_us(20);
*
02AFA:  MOVLW  1A
02AFC:  MOVWF  00
02AFE:  DECFSZ 00,F
02B00:  BRA    2AFE
02B02:  NOP   
.................... 
....................     // PIC18F67J94の12bit ADC値を読み取って返す
....................     return read_adc();
02B04:  BCF    FC0.0
02B06:  BSF    FC0.1
02B08:  BTFSS  FC0.0
02B0A:  GOTO   2B08
02B0E:  MOVF   FC3,W
02B10:  CLRF   03
02B12:  MOVWF  01
02B14:  MOVF   03,W
02B16:  MOVWF  02
02B18:  GOTO   2C96 (RETURN)
.................... }

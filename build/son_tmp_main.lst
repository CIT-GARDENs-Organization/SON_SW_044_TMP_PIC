.................... #include "../../tmp/hardware/mcu/uart.h" // uart_fetch_to_buffer гВТдљњзФ®гБЩгВЛгБЯгВБгВ§гГ≥гВѓгГЂгГЉгГЙ
.................... #ifndef UART_H
.................... #define UART_H
.................... 
.................... #include <stdint.h>
.................... #include <stdbool.h>
.................... 
.................... // _________ defines ________________
.................... 
.................... #define RECEIVE_BUFFER_MAX 32
.................... #define RX_RING_BUFFER_SIZE 64
.................... 
.................... // _____________ values _______________
.................... 
.................... extern volatile unsigned int8 boss_receive_buffer[RECEIVE_BUFFER_MAX];
.................... extern volatile int8 boss_receive_buffer_size;
.................... 
.................... // _______________ functions ___________
.................... 
.................... void setup_uart_to_boss(void);
.................... void clear_receive_signal(unsigned int8 receive_signal[], int8 *receive_signal_size);
.................... 
.................... // --- еЙ≤гВКиЊЉгБњеПЧдњ°гБЂгВИгВЛгГ™гГ≥гВ∞гГРгГГгГХгВ°зФ®йЦҐжХ∞ ---
.................... bool uart_has_data(void);
.................... uint8_t uart_getc(void);
.................... void uart_fetch_to_buffer(void); // гГ™гГ≥гВ∞гГРгГГгГХгВ°гБЛгВЙгГ™гГЛгВҐгГРгГГгГХгВ°гБЄеЃЙеЕ®гБЂеРЄгБДдЄКгБТгВЛ
.................... 
.................... #endif // UART_H
.................... 
.................... 
.................... int1 req_use_smf()
.................... {
....................    fprintf(PC, "Start SMF using reqest seaquence\r\n");
....................    status = SMF_USE_REQ;
....................    is_use_smf_req_in_mission = TRUE;
.................... 
....................    while (TRUE)
....................    {
....................       for (int16 i = 0; i < 1200; i++) // 10 min
....................       {
....................          // вШЕдњЃж≠£: гГЂгГЉгГЧжѓОгБЂеЙ≤гВКиЊЉгБњгГ™гГ≥гВ∞гГРгГГгГХгВ°гБЛгВЙгГЗгГЉгВњгВТеРЄгБДдЄКгБТгВЛеЗ¶зРЖгВТињљеК†
....................          uart_fetch_to_buffer();
.................... 
....................          if (boss_receive_buffer_size > 0)
....................          {
....................             Command command = make_receive_command(boss_receive_buffer, boss_receive_buffer_size);
....................             clear_receive_signal(boss_receive_buffer, &boss_receive_buffer_size);
....................             if (command.frame_id == STATUS_CHECK)
....................             {
....................                transmit_status();
....................                break;
....................             }
....................             else
....................             {
....................                fprintf(PC, "Error! Receiving command inconsistent with the design\r\n");
....................             }
....................          }
....................          delay_ms(500);
....................       }
.................... 
....................       for (int16 i = 0; i < 1200; i++) // 10 min
....................       {
....................          // вШЕдњЃж≠£: еРМжІШгБЂгГЗгГЉгВњгВТеРЄгБДдЄКгБТгВЛ
....................          uart_fetch_to_buffer();
.................... 
....................          if (boss_receive_buffer_size > 0)
....................          {
....................             Command command = make_receive_command(boss_receive_buffer, boss_receive_buffer_size);
....................             clear_receive_signal(boss_receive_buffer, &boss_receive_buffer_size);
....................             if (command.frame_id == IS_SMF_AVAILABLE)
....................             {
....................                if (command.content[0] == ALLOW)
....................                {
....................                   fprintf(PC, "SMF use request allowed\r\n");
....................                   transmit_ack();
....................                   goto NEXT;
....................                }
....................                else
....................                {
....................                   fprintf(PC, "SMF use request denyed\r\n");
....................                   fprintf(PC, "Retry request to BOSS PIC\r\n");
....................                   transmit_ack();
....................                   break;
....................                }
....................             }
....................             else
....................             {
....................                fprintf(PC, "Error! Receiving command inconsistent with the design\r\n");
....................             }
....................          }
....................          delay_ms(500);
....................       }
....................    }
.................... 
.................... NEXT:
....................    is_use_smf_req_in_mission = FALSE;
....................    status = COPYING;
....................    return TRUE;
....................    fprintf(PC, "End SMF using reqest seaquence\r\n");
.................... }
.................... 
.................... 
.................... void finished_use_smf()
.................... {
....................    status = EXECUTING_MISSION;
.................... }
.................... 
.................... void check_and_respond_to_boss()
.................... {
....................    if (uart_has_data())
....................    {
....................       uart_getc();
....................       transmit_status();
....................    }
.................... }

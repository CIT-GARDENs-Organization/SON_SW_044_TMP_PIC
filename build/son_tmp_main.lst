.................... // ============================================================================
.................... // PICLOG 定数定義
.................... // ============================================================================
.................... #define PICLOG_STARTUP     0x00
.................... #define PICLOG_PARAM_START 0x00
.................... #define PICLOG_PARAM_END   0xFF
.................... 
.................... #define PICLOG_PACKET_SIZE 6
.................... #define PICLOG_BLANK_SIZE  4
.................... 
.................... // ============================================================================
.................... // PICLOG データ構造体 (6 Byte)
.................... // ============================================================================
.................... typedef union
.................... {

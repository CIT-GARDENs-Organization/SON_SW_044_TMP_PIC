.................... int8 read_data_byte(Flash flash_stream, unsigned int32 read_address);
.................... 
.................... void write_data_byte(Flash flash_stream, unsigned int32 write_address,int8 write_data);
....................         //
.................... 
.................... 
.................... // ===================== Flash Commands =====================
.................... #define CMD_READ_ID                     0x9F
.................... #define CMD_READ_STATUS_REGISTER        0x05
.................... #define CMD_READ                        0x03//for MT25QL128ABA
.................... #define CMD_4BYTE_READ                  0x13//for MT25QL01GBBB
.................... #define CMD_WRITE_ENABLE                0x06
.................... #define CMD_PAGE_PROGRAM                0x02//for MT25QL128ABA
.................... #define CMD_4BYTE_PAGE_PROGRAM          0x12//for MT25QL01GBBB
.................... #define CMD_SUBSECTOR_4KB_ERASE         0x20//for MT25QL128ABA
.................... #define CMD_4BYTE_SUBSECTOR_4KB_ERASE   0x21//for MT25QL01GBBB
.................... #define CMD_SUBSECTOR_32KB_ERASE        0x52//for MT25QL128ABA
.................... #define CMD_4BYTE_SUBSECTOR_32KB_ERASE  0x5C//for MT25QL01GBBB
.................... #define CMD_SECTOR_ERASE                0xD8//for MT25QL128ABA
.................... #define CMD_4BYTE_SECTOR_ERASE          0xDC//for MT25QL01GBBB
.................... 
.................... // ====================== Value List =====================
.................... #define MANUFACTURER_ID_MICRON 0x20 // Manufacturer ID for Micron flash
.................... #define READ_ID_DATASIZE 20 // 20 bytes for read ID data
.................... 
.................... 
.................... // ====================== Data Structures =====================
.................... typedef union
.................... {
....................     unsigned int8 bytes[READ_ID_DATASIZE]; // 20 bytes for read ID
....................     struct {
....................         unsigned int8 manufacturer_id; // 1 byte
....................         unsigned int8 memory_type;     // 1 byte
....................         unsigned int8 capacity;        // 1 byte
....................         unsigned int8 reserved;       // 1 byte
....................     } fields;
.................... }READ_ID_DATA;
.................... 
.................... 
.................... #endif
.................... 
.................... 
.................... 
.................... 
.................... // ============================================================================
.................... // гӮ°гғӯгғјгғҗгғ«еӨүж•° (и»ўйҖҒзҠ¶ж…ӢгҒ®дҝқжҢҒ)
.................... // ============================================================================
.................... static uint32_t current_transfer_address = 0;
.................... static uint32_t current_transfer_size = 0;
.................... 
.................... // ============================================================================
.................... // SMFпјҲCPLDзөҢз”ұпјүи»ўйҖҒгҒ®е®ҹеҮҰзҗҶ
.................... // ============================================================================
.................... 
.................... void cigs_smf_prepare(void)
.................... {
....................     // дҫӢгҒЁгҒ—гҒҰгҖҒIVгғҮгғјгӮҝпјҲжё©еәҰгғҮгғјгӮҝеҗ«гӮҖпјүгҒ®жңӘгӮігғ”гғјеҲҶгӮ’и»ўйҖҒеҜҫиұЎгҒЁгҒҷгӮӢ
....................     if (str_data.uncopied_counter > 0)
....................     {
....................         // гӮігғ”гғјй–Ӣе§ӢгӮўгғүгғ¬гӮ№гҒ®иЁҲз®— (дҪҝз”ЁжёҲгҒҝйҮҸгҒӢгӮүжңӘгӮігғ”гғјйҮҸгӮ’еј•гҒ„гҒҹе ҙжүҖгҒҢе…Ҳй ӯ)
....................         current_transfer_address = MISF_TMP_STR_DATA_START + str_data.used_counter - str_data.uncopied_counter;
.................... 
....................         // жңҖеӨ§15гғ‘гӮұгғғгғҲеҲҶпјҲ64Byte Г— 15 = 960ByteпјүгӮ’1еӣһгҒ®и»ўйҖҒгӮөгӮӨгӮәгҒЁгҒҷгӮӢ
....................         uint32_t max_transfer_bytes = PACKET_SIZE * SMF_TRANSFER_PACKETS;
.................... 
....................         if (str_data.uncopied_counter >= max_transfer_bytes)
....................         {
....................             current_transfer_size = max_transfer_bytes;
....................         }
....................         else
....................         {
....................             // ж®ӢгӮҠгҒҢ15гғ‘гӮұгғғгғҲжңӘжәҖгҒӘгӮүгҖҒгҒӮгӮӢеҲҶгҒ гҒ‘и»ўйҖҒгҒҷгӮӢ
....................             current_transfer_size = str_data.uncopied_counter;
....................         }
.................... 
....................         fprintf(PC, "\t[SMF] Prepare: Addr=0x%08lX, Size=%lu bytes\r\n", current_transfer_address, current_transfer_size);
....................     }
....................     else
....................     {
....................         current_transfer_size = 0;
....................         fprintf(PC, "\t[SMF] Prepare: No data to copy.\r\n");
....................     }
.................... }
.................... 
.................... void cigs_smf_copy(void)
.................... {
....................     if (current_transfer_size == 0) return;
.................... 
....................     uint8_t buffer[PACKET_SIZE];
....................     uint32_t remaining = current_transfer_size;
....................     uint32_t addr = current_transfer_address;
.................... 
....................     fprintf(PC, "\t[SMF] Copying data to CPLD...\r\n");
.................... 
....................     // CPLDгҒ®гғҒгғғгғ—гӮ»гғ¬гӮҜгғҲгӮ’LowгҒ«гҒ—гҒҰSPIйҖҡдҝЎй–Ӣе§Ӣ
....................     output_low(SMF_CS);
.................... 
....................     // гғ‘гӮұгғғгғҲеҚҳдҪҚгҒ§иӘӯгҒҝеҮәгҒ—гҒҰCPLDгҒёи»ўйҖҒгҒҷгӮӢ
....................     while (remaining > 0)
....................     {
....................         uint8_t size = (remaining >= PACKET_SIZE) ? PACKET_SIZE : remaining;
.................... 
....................         // 1. MIS_FM(гғҹгғғгӮ·гғ§гғігғ•гғ©гғғгӮ·гғҘ)гҒӢгӮүгғҮгғјгӮҝгӮ’иӘӯгҒҝеҮәгҒ—
....................         read_data_bytes(mis_fm, addr, (int8*)buffer, size);
.................... 
....................         // 2. SPI2(SMF_STREAM)зөҢз”ұгҒ§CPLDгҒёйҖҒдҝЎ
....................         for (uint8_t i = 0; i < size; i++)
....................         {
....................             spi_xfer(SMF_STREAM, buffer[i]);
....................         }
.................... 
....................         addr += size;
....................         remaining -= size;
.................... 
....................         // гғ‘гӮұгғғгғҲи»ўйҖҒй–“гҒ®гӮҰгӮ§гӮӨгғҲпјҲCPLDеҒҙгҒ®еҮҰзҗҶиҗҪгҒЎгӮ’йҳІгҒҗгҒҹгӮҒйҒ©е®ңиӘҝж•ҙпјү
....................         delay_us(100);
....................     }
.................... 
....................     // CPLDгҒ®гғҒгғғгғ—гӮ»гғ¬гӮҜгғҲгӮ’HighгҒ«гҒ—гҒҰSPIйҖҡдҝЎзөӮдәҶ
....................     output_high(SMF_CS);
.................... 
....................     fprintf(PC, "\t[SMF] Copy Complete.\r\n");
.................... }
.................... 
.................... void cigs_smf_permit(void)
.................... {
....................     if (current_transfer_size > 0)
....................     {
....................         // и»ўйҖҒгҒҢжҲҗеҠҹгҒ—гҒҹгҒ®гҒ§гҖҒжңӘгӮігғ”гғјгӮ«гӮҰгғігӮҝгӮ’жёӣз®—гҒҷгӮӢ
....................         str_data.uncopied_counter -= current_transfer_size;
....................         current_transfer_size = 0;
.................... 
....................         // жӣҙж–°гҒ•гӮҢгҒҹгӮ«гӮҰгғігӮҝжғ…е ұгӮ’FlashгҒ®гӮўгғүгғ¬гӮ№з®ЎзҗҶй ҳеҹҹгҒ«дҝқеӯҳгҒҷгӮӢ
....................         write_misf_address_area();
.................... 
....................         fprintf(PC, "\t[SMF] Permit: Counters updated and saved.\r\n");
....................     }
.................... }

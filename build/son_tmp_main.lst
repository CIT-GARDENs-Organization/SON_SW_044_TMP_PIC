.................... // ============================================================================
.................... // PICLOG データ構造体 (6 Byte)
.................... // ============================================================================
.................... typedef union
.................... {
....................     struct
....................     {
....................         uint32_t time;       // 4 Byte: タイムスタンプ
....................         uint8_t  function;   // 1 Byte: 実行関数・イベントID
....................         uint8_t  parameter;  // 1 Byte: パラメータ・状態
....................     } fields;
....................     uint8_t bytes[PICLOG_PACKET_SIZE];
.................... } PICLOG_t;
.................... 

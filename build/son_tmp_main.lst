.................... volatile uint8_t timer_tick_100ms = 0;
.................... 
.................... #INT_TIMER1
.................... void TIMER1_isr()
.................... {
....................     set_timer1(15536);
*
000BE:  MOVLW  3C
000C0:  MOVWF  FCF
000C2:  MOVLW  B0
000C4:  MOVWF  FCE
000C6:  NOP   
....................     timer_tick_100ms++;
000C8:  MOVLB  1
000CA:  INCF   x2B,F
.................... 
....................     if (timer_tick_100ms >= 10)
000CC:  MOVF   x2B,W
000CE:  SUBLW  09
000D0:  BTFSS  FD8.0
000D2:  BRA    00DA
000D4:  MOVLB  0
000D6:  GOTO   00F2
000DA:  MOVLB  0
....................     {
....................         timer_tick_100ms = 0;
000DC:  MOVLB  1
000DE:  CLRF   x2B
....................         sec++;
000E0:  MOVLW  01

.................... #define MISF_TMP_DATA_TABLE_END      0x00000FFF // 1مپ¤ç›® (4KB)
.................... #define MISF_TMP_DATA_TABLE_BK_START 0x00001000 // 2مپ¤ç›® (مƒگمƒƒم‚¯م‚¢مƒƒمƒ—/é€€éپ؟ç”¨: 4KB)
.................... #define MISF_TMP_DATA_TABLE_BK_END   0x00001FFF

.................... #define SAMP_RATE_4865MS             0x08  // 4.865ç§’ (0.5ه‘¨ه›‍é€£ç¶ڑè¨ˆو¸¬)
.................... #define SAMP_RATE_9730MS             0x09  // 9.730ç§’ (1ه‘¨ه›‍é€£ç¶ڑè¨ˆو¸¬)
.................... 

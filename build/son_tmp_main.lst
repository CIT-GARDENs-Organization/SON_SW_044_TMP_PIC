.................... 
.................... void switch_channel(uint8_t ch)
.................... {
....................     // MAX4734EUB+ は 2bit (DIO1, DIO0) で 4ch を切り替える
....................     if (ch & 0x01)
....................     {
....................         output_high(PIN_SW_DIO0);
....................     }
....................     else
....................     {
....................         output_low(PIN_SW_DIO0);
....................     }
.................... 
....................     if (ch & 0x02)
....................     {

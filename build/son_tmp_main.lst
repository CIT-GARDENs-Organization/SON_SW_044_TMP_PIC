.................... // жЄ©еЇ¶гГЗгГЉгВњзФ®гГСгВ±гГГгГИжІЛйА†дљУ (64Byte)
.................... // ============================================================================
.................... typedef struct
.................... {
....................     uint8_t packetNum;       // гГСгВ±гГГгГИзХ™еПЈ (1 Byte)
....................     uint8_t tempData[62];    // жЄ©еЇ¶гГЗгГЉгВњжЬђдљУ (62 Byte = 12bit x 41гГЗгГЉгВњ)
....................     uint8_t crc8;            // CRC-8 (1 Byte)
.................... } TempPacket;
.................... 
.................... // гГ°гГҐгГ™гГРгГГгГХгВ°зФ®еЕ±зФ®дљУ
.................... typedef union
.................... {
....................     uint8_t raw[PACKET_SIZE];
....................     TempPacket temp;

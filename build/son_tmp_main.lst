....................     uint8_t tempData[62];    // ц╕йх║жуГЗуГ╝уВ┐цЬмф╜У (62 Byte = 12bit x 41уГЗуГ╝уВ┐)
....................     uint8_t crc8;            // CRC-8 (1 Byte)
.................... } TempPacket;
.................... 
.................... // уГбуГвуГкуГРуГГуГХуВбчФихЕ▒чФиф╜У
.................... typedef union
.................... {
....................     uint8_t raw[PACKET_SIZE];
....................     TempPacket temp;

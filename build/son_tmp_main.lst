.................... #define SAMP_RATE_1000MS             0x05  // 1.00з§’
.................... #define SAMP_RATE_5000MS             0x06  // 5.00з§’
.................... #define SAMP_RATE_2432MS             0x07  // 2.432з§’ (0.25е‘ЁеӣһйҖЈз¶ҡиЁҲжё¬)
.................... #define SAMP_RATE_4865MS             0x08  // 4.865з§’ (0.5е‘ЁеӣһйҖЈз¶ҡиЁҲжё¬)
.................... #define SAMP_RATE_9730MS             0x09  // 9.730з§’ (1е‘ЁеӣһйҖЈз¶ҡиЁҲжё¬)
.................... 

.................... // ============================================================================
.................... // ТИЕт║дсЃЄсЃ╝сѓ┐ућесЃЉсѓ▒сЃЃсЃѕТДІжђаСйЊ (64Byte)
.................... // ============================================================================
.................... typedef struct
.................... {
....................     uint8_t packetNum;       // сЃЉсѓ▒сЃЃсЃѕуЋфтЈи (1 Byte)
....................     uint8_t tempData[62];    // ТИЕт║дсЃЄсЃ╝сѓ┐ТюгСйЊ (62 Byte = 12bit x 41сЃЄсЃ╝сѓ┐)
....................     uint8_t crc8;            // CRC-8 (1 Byte)
.................... } TempPacket;
.................... 
.................... // сЃАсЃбсЃфсЃљсЃЃсЃЋсѓАућетЁ▒ућеСйЊ
.................... typedef union
.................... {
....................     uint8_t raw[PACKET_SIZE];
....................     TempPacket temp;
.................... } TempPacketBuffer;
.................... 
.................... // ============================================================================
.................... // тцќжЃетЁгжќІжќбТЋ░сЃЌсЃГсЃѕсѓ┐сѓцсЃЌ
.................... // ============================================================================
.................... 
.................... // тєЁУћхADCсЂ«тѕЮТюЪтїќ
.................... void temp_io_init(void);
.................... 
.................... // тєЁУћхADCсЂІсѓЅТИЕт║дсѓ╗сЃ│сѓхсЃ╝сЂ«тђцсѓњУфГсЂ┐тЈќсѓІ (12bit)
.................... uint16_t read_adc_internal(void);
.................... 
.................... // ТИЕт║дУеѕТИгсѓисЃ╝сѓ▒сЃ│сѓ╣сЂ«т«ЪУАїсЂеFlashсЂИсЂ«С┐ЮтГў
.................... // startPacketNum: жќІтДІсЃЉсѓ▒сЃЃсЃѕуЋфтЈи (19)
.................... // packetCount: т«ЪУАїсЂЎсѓІсЃЉсѓ▒сЃЃсЃѕТЋ░ (14)
.................... void execute_temp_measurement(uint8_t startPacketNum, uint8_t packetCount);
.................... 

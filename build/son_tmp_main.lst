021C0:  ADDWFC x19,F
....................         piclog_data.uncopied_counter += PICLOG_BLANK_SIZE;
021C2:  MOVLW  04
021C4:  ADDWF  x1A,F
021C6:  MOVLW  00
021C8:  ADDWFC x1B,F
021CA:  MOVLW  00
021CC:  ADDWFC x1C,F
021CE:  MOVLW  00
021D0:  ADDWFC x1D,F
....................         piclog_data.reserve_counter1 = 0; // 次の64Byteブロックのためにリセット
021D2:  CLRF   x1E
021D4:  MOVLB  0
....................     }
.................... 
....................     // フラッシュのアドレス管理領域を更新
....................     write_misf_address_area();
021D6:  CALL   1FC2
021DA:  RETURN 0
.................... }

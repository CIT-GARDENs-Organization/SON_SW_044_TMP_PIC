.................... #define CMD_STR_DEBUG                0xA1
.................... #define CMD_STR_PRINT                0xA2
.................... #define CMD_STR_DEBUG_SAVE           0xA3
.................... #define CMD_MISSION_ABORT            0xAF
.................... 
.................... // --- гБЭгБЃдїЦ ---
.................... #define CMD_RETURN_TIME              0xB0
.................... 
.................... // вШЕдњЃж≠£: зЙ©зРЖзЪДгБЂADCеЗ¶зРЖгБМйЦУгБЂеРИгВПгБ™гБДгБЯгВБ 10ms, 50ms гБЃи®≠еЃЪгВТйЩ§е§ЦгБЧгБЊгБЧгБЯ
.................... // #define SAMP_RATE_10MS               0x01  // 0.01зІТ

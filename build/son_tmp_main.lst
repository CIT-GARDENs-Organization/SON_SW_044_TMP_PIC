.................... // ============================================================================
.................... // µû░ÒüùÒüäÒâíÒâóÒâ¬Òâ×ÒââÒâùÕ«Üþ¥® (MT25QL128ABA: 16MB)
.................... // ============================================================================
.................... #define MISF_START 0x00000000
.................... #define MISF_END   0x00FFFFFF
.................... 
.................... #define SECTOR_64K_BYTE  0x10000
.................... 
.................... // ----------------------------------------------------
.................... // 1. þ«íþÉåþö¿ÒâçÒâ╝Òé┐ÚáÿÕƒƒ (4KB ÒéÁÒâûÒé╗Òé»Òé┐ ├ù 2)
.................... // ----------------------------------------------------
.................... #define MISF_TMP_DATA_TABLE_SIZE     64
.................... #define MISF_TMP_DATA_TABLE_START    0x00000000
.................... #define MISF_TMP_DATA_TABLE_END      0x00000FFF // 1Òüñþø« (4KB)
.................... #define MISF_TMP_DATA_TABLE_BK_START 0x00001000 // 2Òüñþø« (ÒâÉÒââÒé»ÒéóÒââÒâù/ÚÇÇÚü┐þö¿: 4KB)
.................... #define MISF_TMP_DATA_TABLE_BK_END   0x00001FFF
.................... 
.................... // ----------------------------------------------------
.................... // 2. PICLOG ÚáÿÕƒƒ (64KB Òé╗Òé»Òé┐ ├ù 1)
.................... // ÔÇ╗ÚÇ▒1Õø×Òü«Úüïþö¿Òüº1Õ╣┤ÚûôÒü½þ┤ä3.3KBµÂêÞ▓╗ÒÇéþ┤ä19Õ╣┤Õêåõ┐ØÕ¡ÿÕÅ»Þâ¢ÒÇé
.................... // ----------------------------------------------------
.................... #define MISF_TMP_PICLOG_START        0x00010000
.................... #define MISF_TMP_PICLOG_END          0x0001FFFF
.................... 
.................... // ----------------------------------------------------
.................... // 3. STRÒâçÒâ╝Òé┐ÚáÿÕƒƒ (µ«ïÒéèÒüÖÒü╣Òüª: þ┤ä15.8MB)
.................... // ÔÇ╗Õ║âÕñºÒü¬Òâ¡Òâ╝Òé½Òâ½ÒâÉÒââÒâòÒéíÒü¿ÒüùÒüªõ¢┐þö¿ÒÇéµ£¬ÚÇüõ┐íÕêåÒéÆÒüôÒüôÒüïÒéëCPLDÒü©ÚÇüÒéïÒÇé
.................... // ----------------------------------------------------
.................... #define MISF_TMP_STR_DATA_START      0x00020000
.................... #define MISF_TMP_STR_DATA_END        0x00FFFFFF
.................... 
.................... // ============================================================================
.................... // ÒâçÒâ╝Òé┐µºïÚÇáõ¢ôÕ«Üþ¥®
.................... // ============================================================================
.................... 
.................... // ÒâòÒâ®ÒââÒéÀÒâÑÒé½ÒéªÒâ│Òé┐µºïÚÇáõ¢ô (11 Bytes)
.................... typedef struct
.................... {
....................     uint8_t   mission_id;
....................     uint32_t  used_counter;
....................     uint32_t  uncopied_counter;
....................     uint8_t   reserve_counter1;
....................     uint8_t   reserve_counter2;
.................... } Flash_t;
.................... 
.................... // ÒâåÒâ╝ÒâûÒâ½õ┐ØÕ¡ÿþö¿Òü«64ByteÒâæÒé▒ÒââÒâêµºïÚÇáõ¢ô
.................... typedef union
.................... {
....................     struct
....................     {
....................         union
....................         {
....................             struct
....................             {
....................                 Flash_t piclog;
....................                 Flash_t str_data;
....................             } logdata;
....................             uint8_t reserve[63];
....................         } payload;
....................         uint8_t crc; // 1ÒâÉÒéñÒâêÒü«CRC
....................     } packet;
....................     uint8_t bytes[64];
.................... } FlashData_t;

....................     unsigned int32 used_size;
....................     unsigned int8 loop_counter;
....................     unsigned int8 reserved[3];
.................... } partition_header_t;
.................... 
.................... // payloadمپ«è¤‡و•°مپ®partition_headerم‚’ن¸¦مپ¹م‚‹
.................... typedef union {
....................     unsigned int8 bytes[PACKET_SIZE];  // ç”ںمƒ‡مƒ¼م‚؟م‚¢م‚¯م‚»م‚¹ç”¨
.................... 
....................     struct {
....................         union {
....................             struct {
....................                 partition_header_t piclog;
....................                 partition_header_t enviroment;
....................                 partition_header_t iv_head;
....................                 partition_header_t iv_data;
....................             }cigs;
.................... 
....................             struct {
....................                 partition_header_t piclog;
....................                 partition_header_t enviroment;
....................                 partition_header_t iv_head;
....................                 partition_header_t iv_data;
....................             } satolab;
....................             // مƒ•مƒ©مƒƒمƒˆمپ«م‚¢م‚¯م‚»م‚¹مپ—مپںمپ„مپ¨مپچç”¨
....................             partition_header_t headers[(PACKET_SIZE - 1) / sizeof(partition_header_t)];
....................         } payload;
.................... 
....................         unsigned int8 crc;  // وœ€ه¾Œمپ®1مƒگم‚¤مƒˆ
....................     };
.................... } smf_data_table_t;

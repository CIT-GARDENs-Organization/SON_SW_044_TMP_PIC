.................... /*
.................... #define ERASE_ALL               0X80
.................... #define ERASE_1SECTOR           0X81
.................... #define ERASE_4kBYTE_SUBSECTOR  0X82
.................... #define ERASE_64kBYTE_SUBSECTOR 0X83

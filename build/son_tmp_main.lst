.................... #include <string.h>
.................... #include "../../system/son_tmp_config.h"
.................... 
.................... // ============================================================================
.................... // ж–°гҒ—гҒ„гғЎгғўгғӘгғһгғғгғ—е®ҡзҫ© (MT25QL128ABA: 16MB)
.................... // ============================================================================
.................... #define MISF_START 0x00000000
.................... #define MISF_END   0x00FFFFFF
.................... 
.................... #define SECTOR_64K_BYTE  0x10000
.................... 
.................... // ----------------------------------------------------
.................... // 1. з®ЎзҗҶз”ЁгғҮгғјгӮҝй ҳеҹҹ (4KB гӮөгғ–гӮ»гӮҜгӮҝ Г— 2)
.................... // ----------------------------------------------------
.................... #define MISF_TMP_DATA_TABLE_SIZE     64
.................... #define MISF_TMP_DATA_TABLE_START    0x00000000
.................... #define MISF_TMP_DATA_TABLE_END      0x00000FFF // 1гҒӨзӣ® (4KB)
.................... #define MISF_TMP_DATA_TABLE_BK_START 0x00001000 // 2гҒӨзӣ® (гғҗгғғгӮҜгӮўгғғгғ—/йҖҖйҒҝз”Ё: 4KB)
.................... #define MISF_TMP_DATA_TABLE_BK_END   0x00001FFF
.................... 
.................... // ----------------------------------------------------
.................... // 2. PICLOG й ҳеҹҹ (64KB гӮ»гӮҜгӮҝ Г— 1)
.................... // вҖ»йҖұ1еӣһгҒ®йҒӢз”ЁгҒ§1е№ҙй–“гҒ«зҙ„3.3KBж¶ҲиІ»гҖӮзҙ„19е№ҙеҲҶдҝқеӯҳеҸҜиғҪгҖӮ
.................... // ----------------------------------------------------
.................... #define MISF_TMP_PICLOG_START        0x00010000
.................... #define MISF_TMP_PICLOG_END          0x0001FFFF
.................... 
.................... // ----------------------------------------------------
.................... // 3. STRгғҮгғјгӮҝй ҳеҹҹ (ж®ӢгӮҠгҒҷгҒ№гҒҰ: зҙ„15.8MB)
.................... // вҖ»еәғеӨ§гҒӘгғӯгғјгӮ«гғ«гғҗгғғгғ•гӮЎгҒЁгҒ—гҒҰдҪҝз”ЁгҖӮжңӘйҖҒдҝЎеҲҶгӮ’гҒ“гҒ“гҒӢгӮүCPLDгҒёйҖҒгӮӢгҖӮ
.................... // ----------------------------------------------------
.................... #define MISF_TMP_STR_DATA_START      0x00020000
.................... #define MISF_TMP_STR_DATA_END        0x00FFFFFF
.................... 
.................... // ============================================================================
.................... // гғҮгғјгӮҝж§ӢйҖ дҪ“е®ҡзҫ©
.................... // ============================================================================
.................... 
.................... // гғ•гғ©гғғгӮ·гғҘгӮ«гӮҰгғігӮҝж§ӢйҖ дҪ“ (11 Bytes)
.................... typedef struct
.................... {
....................     uint8_t   mission_id;
....................     uint32_t  used_counter;
....................     uint32_t  uncopied_counter;
....................     uint8_t   reserve_counter1;
....................     uint8_t   reserve_counter2;
.................... } Flash_t;
.................... 
.................... // гғҶгғјгғ–гғ«дҝқеӯҳз”ЁгҒ®64Byteгғ‘гӮұгғғгғҲж§ӢйҖ дҪ“
.................... typedef union
.................... {
....................     struct
....................     {
....................         union
....................         {
....................             struct
....................             {
....................                 Flash_t piclog;
....................                 Flash_t str_data;
....................             } logdata;
....................             uint8_t reserve[63];
....................         } payload;
....................         uint8_t crc; // 1гғҗгӮӨгғҲгҒ®CRC
....................     } packet;
....................     uint8_t bytes[64];
.................... } FlashData_t;
.................... 
.................... typedef struct
.................... {
....................     uint32_t start_address;
....................     uint32_t end_address;
.................... } MisfStatusStruct;
.................... 
.................... typedef struct
.................... {
....................     uint32_t start_address;
....................     uint32_t size;
.................... } MisfWriteStruct;
.................... 
.................... // ============================================================================
.................... // гӮ°гғӯгғјгғҗгғ«еӨүж•° (е®ЈиЁҖгҒ®гҒҝгҖҒе®ҹдҪ“гҒҜ.cгғ•гӮЎгӮӨгғ«гҒ«иЁҳиҝ°)
.................... // ============================================================================
.................... extern Flash_t piclog_data;
.................... extern Flash_t str_data;
.................... 
.................... // ============================================================================
.................... // еӨ–йғЁе…¬й–Ӣй–ўж•°гғ—гғӯгғҲгӮҝгӮӨгғ—
.................... // ============================================================================
.................... void misf_init(void);
.................... void write_misf_address_area(void);
.................... MisfStatusStruct get_misf_status_struct(uint8_t mission_id);
.................... MisfWriteStruct get_misf_write_struct(uint8_t mission_id);
.................... void print_flash_status(void);
.................... 
.................... #endif // SON_TMP_FLASH_H

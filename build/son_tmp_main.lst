.................... 
.................... void cigs_system_init(void)
.................... {
....................     fprintf(PC, "CIGS System Initialize Start\r\n");
.................... 
....................     disable_interrupts(GLOBAL);
.................... 
....................     setup_timer();
....................     setup_uart_to_boss();
.................... 
....................     status = 0;

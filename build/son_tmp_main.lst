.................... // ============================================================================
.................... typedef struct
.................... {
....................     uint8_t packetNum;       // パケット番号 (1 Byte)
....................     uint8_t tempData[62];    // 温度データ本体 (62 Byte = 12bit x 41データ)
....................     uint8_t crc8;            // CRC-8 (1 Byte)
.................... } TempPacket;
.................... 
.................... // メモリバッファ用共用体
.................... typedef union
.................... {
....................     uint8_t raw[PACKET_SIZE];
....................     TempPacket temp;
.................... } TempPacketBuffer;

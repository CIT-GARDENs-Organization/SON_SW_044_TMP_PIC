.................... 
.................... // テーブル保存用の64Byteパケット構造体
.................... typedef union
.................... {
....................     struct
....................     {
....................         union
....................         {
....................             struct
....................             {
....................                 Flash_t piclog;
....................                 Flash_t environment;
....................                 Flash_t iv_header;
....................                 Flash_t iv_data;
....................             } logdata;
....................             uint8_t reserve[63];
....................         } payload;
....................         uint8_t crc; // 1バイトのCRC
....................     } packet;
....................     uint8_t bytes[64];
.................... } FlashData_t;
.................... 
